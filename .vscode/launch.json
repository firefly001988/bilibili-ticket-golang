{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Wails: Production myproject",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/myproject.exe",
      "preLaunchTask": "build",
      "cwd": "${workspaceFolder}/cmd/gui"
    },
    {
      "name": "Wails: Debug myproject",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/myproject.exe",
      "preLaunchTask": "build debug",
      "cwd": "${workspaceFolder}/cmd/gui"
    },
    {
      "name": "Wails: Dev myproject",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/myproject.exe",
      "preLaunchTask": "build dev",
      "cwd": "${workspaceFolder}/cmd/gui"
    },
    {
      "name": "Worker: serve (gRPC)",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/ticket-worker.exe",
      "args": [
        "serve",
        "--config",
        "${workspaceFolder}/cmd/ticket-worker/data/worker/worker.json"
      ],
      "preLaunchTask": "build ticket-worker",
      "cwd": "${workspaceFolder}/cmd/ticket-worker"
    },
    {
      "name": "Worker: run (single task)",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${workspaceFolder}/build/bin/ticket-worker.exe",
      "args": [
        "run",
        "--task",
        "${workspaceFolder}/cmd/ticket-worker/data/worker/task.json"
      ],
      "preLaunchTask": "build ticket-worker",
      "cwd": "${workspaceFolder}/cmd/ticket-worker"
    }
  ]
}